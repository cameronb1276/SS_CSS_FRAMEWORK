# Local development defaults
PORT=3004
LOCAL_DEVELOPMENT_MODE=true
THEME_SETTINGS_DATA_DIR=./data
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3004,http://localhost:8080,http://127.0.0.1:3000,http://127.0.0.1:3004,http://127.0.0.1:8080
MAX_JSON_BODY_SIZE=256kb
MAX_CUSTOM_CSS_BYTES=100000
MAX_CUSTOM_JS_BYTES=50000
CUSTOM_JS_EDITING_ENABLED=false
CUSTOM_HTML_BLOCKS_ENABLED=false
PUBLIC_THEME_READ_ENABLED=true
WRITE_RATE_LIMIT_MAX=60
WRITE_RATE_LIMIT_WINDOW_MS=60000

# Production mode must set a real secret outside the repo.
# NODE_ENV=production
# THEME_BACKEND_PRODUCTION_MODE=true
# LOCAL_DEVELOPMENT_MODE=false
# ADMIN_API_TOKEN=replace-with-secret-from-your-secret-manager
